{
  "name": "openclaw-manager",
  "version": "0.2.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:headed": "playwright test --config playwright.config.ts --headed",
    "setup:node": "node scripts/fetch-node.cjs",
    "build:installer": "npm run setup:node && npm run build && electron-builder",
    "release:all": "npm run build:installer && uv run scripts/upload-ms/upload.py"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "@vuesimple/vs-toast": "^3.1.6",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vue-tsc": "^3.3.7"
  }
}
